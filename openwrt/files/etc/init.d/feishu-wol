#!/bin/sh /etc/rc.common
# feishu-wol — OpenWrt procd service  (reads /etc/config/feishu-wol via UCI)

START=99
STOP=10
USE_PROCD=1

PROG=/usr/bin/feishu-wol

start_service() {
	local enabled
	config_load feishu-wol
	config_get_bool enabled main enabled 0
	[ "$enabled" -eq 0 ] && return 0

	local app_id app_secret interface broadcast_ip port log_level log_file
	local telegram_enabled telegram_bot_token telegram_proxy_url selfhost_client_enabled selfhost_server_url selfhost_device_token selfhost_poll_interval
	config_get app_id      main app_id      ""
	config_get app_secret  main app_secret  ""
	config_get interface   main interface   "br-lan"
	config_get broadcast_ip main broadcast_ip "255.255.255.255"
	config_get port        main port        "9"
	config_get log_level   main log_level   "info"
	config_get log_file    main log_file    "/tmp/feishu-wol.log"
	config_get_bool telegram_enabled main telegram_enabled 0
	config_get telegram_bot_token main telegram_bot_token ""
	config_get telegram_proxy_url main telegram_proxy_url ""
	config_get_bool selfhost_client_enabled main selfhost_client_enabled 0
	config_get selfhost_server_url main selfhost_server_url ""
	config_get selfhost_device_token main selfhost_device_token ""
	config_get selfhost_poll_interval main selfhost_poll_interval "5s"

	[ "$telegram_enabled" -eq 1 ] || telegram_bot_token=""
	[ "$selfhost_client_enabled" -eq 1 ] || selfhost_server_url=""

	# Collect list values into comma-separated strings.
	local mac_list="" device_list="" oid_list="" chat_list="" telegram_uid_list="" telegram_chat_list=""
	append_mac() { mac_list="${mac_list:+$mac_list,}$1"; }
	append_device() {
		local section="$1" name mac ip iface bcast dport record
		config_get name "$section" name ""
		config_get mac "$section" mac ""
		config_get ip "$section" ip ""
		config_get iface "$section" interface ""
		config_get bcast "$section" broadcast_ip ""
		config_get dport "$section" port ""
		[ -n "$mac" ] || return 0
		record="${name}|${mac}|${ip}|${iface}|${bcast}|${dport}"
		device_list="${device_list:+$device_list;}$record"
	}
	append_oid() {
		[ -n "$1" ] && oid_list="${oid_list:+$oid_list,}$1"
	}
	append_chat() {
		[ -n "$1" ] && chat_list="${chat_list:+$chat_list,}$1"
	}
	append_tg_uid() {
		[ -n "$1" ] && telegram_uid_list="${telegram_uid_list:+$telegram_uid_list,}$1"
	}
	append_tg_chat() {
		[ -n "$1" ] && telegram_chat_list="${telegram_chat_list:+$telegram_chat_list,}$1"
	}
	config_list_foreach main mac_addresses append_mac
	config_foreach append_device device
	config_list_foreach main allowed_open_ids append_oid
	config_list_foreach main allowed_chat_ids append_chat
	config_list_foreach main telegram_allowed_user_ids append_tg_uid
	config_list_foreach main telegram_allowed_chat_ids append_tg_chat

	# Ensure log directory exists (/var is a symlink to /tmp on OpenWrt)
	[ -n "$log_file" ] && mkdir -p "$(dirname "$log_file")" && touch "$log_file"

	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param env \
		FEISHU_APP_ID="$app_id" \
		FEISHU_APP_SECRET="$app_secret" \
		FEISHU_WOL_MACS="$mac_list" \
		FEISHU_WOL_INTERFACE="$interface" \
		FEISHU_WOL_BROADCAST="$broadcast_ip" \
		FEISHU_WOL_PORT="$port" \
		FEISHU_WOL_DEVICES="$device_list" \
		FEISHU_LOG_LEVEL="$log_level" \
		FEISHU_LOG_FILE="$log_file" \
		FEISHU_ALLOWED_OPEN_IDS="$oid_list" \
		FEISHU_ALLOWED_CHAT_IDS="$chat_list" \
		FEISHU_TELEGRAM_ENABLED="$telegram_enabled" \
		FEISHU_TELEGRAM_BOT_TOKEN="$telegram_bot_token" \
		FEISHU_TELEGRAM_ALLOWED_USER_IDS="$telegram_uid_list" \
		FEISHU_TELEGRAM_ALLOWED_CHAT_IDS="$telegram_chat_list" \
		FEISHU_TELEGRAM_PROXY_URL="$telegram_proxy_url" \
		FEISHU_SELFHOST_CLIENT_ENABLED="$selfhost_client_enabled" \
		FEISHU_SELFHOST_SERVER_URL="$selfhost_server_url" \
		FEISHU_SELFHOST_DEVICE_TOKEN="$selfhost_device_token" \
		FEISHU_SELFHOST_POLL_INTERVAL="$selfhost_poll_interval"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param file /etc/config/feishu-wol
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "feishu-wol"
}
